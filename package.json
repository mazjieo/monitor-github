{
  "name": "monitor-github",
  "version": "1.0.0",
  "description": "Open source project opportunity radar for indie developers and programmers.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "astro dev --host 127.0.0.1",
    "start": "node server/index.js",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1",
    "refresh": "node server/scripts/refresh.js",
    "export": "node -e \"import('./server/export-static.js').then(({ exportStaticData }) => console.log(JSON.stringify(exportStaticData(), null, 2)))\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "node-cron": "^4.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1"
  }
}
