---
import TrendApp from "../components/TrendApp.jsx";
import "../styles.css";

const title = "开源项目机会雷达";
const description = "面向独立开发者和程序员的开源项目机会雷达，用真实 star 快照、机会评分和可疑信号发现值得研究、复用、二开或变现的项目。";
const canonical = "https://mazjieo.github.io/monitor-github/";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "开源项目机会雷达",
  url: canonical,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  description
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <main>
      <section class="hero">
        <a class="source-link" href="https://github.com/mazjieo/monitor-github" target="_blank" rel="noreferrer">查看源码</a>
      </section>

      <noscript>
        <div class="alert">需要启用 JavaScript 才能使用筛选、搜索和自动刷新。</div>
      </noscript>

      <TrendApp client:load />
    </main>
  </body>
</html>
