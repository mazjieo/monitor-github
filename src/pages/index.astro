---
import TrendApp from "../components/TrendApp.jsx";
import "../styles.css";
import trendData from "../../public/data/trending.json";

const title = "GitHub Star Radar - 开源项目升星速度榜";
const description = "追踪 GitHub 上 500 stars 以上仓库的升星速度，用真实快照、语言筛选和关键词搜索发现正在加速的开源项目。";
const canonical = "https://mazjieo.github.io/monitor-github/";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "GitHub Star Radar",
  url: canonical,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  description
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <main>
      <section class="hero">
        <div>
          <div class="eyebrow">GitHub Star Radar</div>
          <h1>发现正在加速的开源项目</h1>
          <p>基于 GitHub Actions 定时快照，按 6 小时、24 小时、3 天和 7 天窗口计算 star 增速，帮你更早看见开发者生态里的新信号。</p>
        </div>
        <a class="source-link" href="https://github.com/mazjieo/monitor-github" target="_blank" rel="noreferrer">查看源码</a>
      </section>

      <noscript>
        <div class="alert">需要启用 JavaScript 才能使用筛选、搜索和自动刷新。</div>
      </noscript>

      <TrendApp initialData={trendData} client:load />
    </main>
  </body>
</html>
